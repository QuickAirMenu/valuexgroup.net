# =====================================
# إعدادات SMTP - الإيميل المرسل
# SMTP Settings - Sender Email
# =====================================
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USERNAME=site@valuexgroup.net
MAIL_PASSWORD=your_password_here
MAIL_FROM=site@valuexgroup.net
MAIL_FROM_NAME=Value X Group

# =====================================
# الإيميل المستقبل (صندوق الوارد)
# Recipient Email (Inbox)
# =====================================
MAIL_TO=info@valuexgroup.net

# =====================================
# إعدادات هوية الإيميل (الألوان والشعار)
# Email Branding Settings (Colors & Logo)
# =====================================
BRAND_PRIMARY_COLOR=#CDAA72
BRAND_SECONDARY_COLOR=#2D2D1D
BRAND_LOGO_URL=https://valuexgroup.net/assets/img/logo/value-x-group-logo.png
BRAND_WEBSITE=valuexgroup.net

# =====================================
# معلومات الشركة
# Company Information
# =====================================
COMPANY_NAME=Value X Group for Business Development
COMPANY_NAME_AR=مجموعة فاليو إكس لتطوير الأعمال
COMPANY_EMAIL=info@valuexgroup.net
